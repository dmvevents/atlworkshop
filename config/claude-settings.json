{
  "mcpServers": {
    "zoekt-search": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/zoekt-search/server.js"
      ],
      "env": {
        "ZOEKT_URL": "http://localhost:6070"
      }
    },
    "opengrok-search": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/opengrok-search/server.js"
      ],
      "env": {
        "OPENGROK_URL": "http://localhost:8080"
      }
    },
    "ragflow-query": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/ragflow-query/server.js"
      ],
      "env": {
        "RAGFLOW_URL": "http://localhost:9380",
        "RAGFLOW_API_KEY": "${RAGFLOW_API_KEY}"
      }
    },
    "tavily-search": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/tavily-search/server.js"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "semantic-scholar": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/semantic-scholar/server.js"
      ],
      "env": {
        "S2_API_KEY": ""
      }
    },
    "codegraph-context": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/codegraph-context/server.js"
      ],
      "env": {
        "CGC_WORKSPACE": "<YOUR_PROJECT_SRC_DIR>",
        "CGC_DB_PATH": "<HOME>/.codegraph"
      }
    },
    "openrouter-gateway": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/openrouter-gateway/server.js"
      ],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
        "OPENROUTER_DEFAULT_MODEL": "google/gemini-2.5-pro"
      }
    },
    "litellm-proxy": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/litellm-proxy/server.js"
      ],
      "env": {
        "LITELLM_PROXY_URL": "http://localhost:4000",
        "LITELLM_API_KEY": "${LITELLM_API_KEY}",
        "LITELLM_DEFAULT_MODEL": "gemini/gemini-3-pro-preview"
      }
    },
    "efa-gpu-docs": {
      "command": "<HPC_STACK_ROOT>/external/efa-nccl-doc/mcp-server/venv/bin/python3",
      "args": [
        "<HPC_STACK_ROOT>/external/efa-nccl-doc/mcp-server/server.py"
      ],
      "env": {}
    },
    "github": {
      "command": "github-mcp-server",
      "args": ["stdio"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "<YOUR_GITHUB_TOKEN>"
      }
    },
    "kubernetes": {
      "command": "kubernetes-mcp-server",
      "args": [],
      "env": {}
    },
    "cplusplus-analysis": {
      "command": "<HPC_STACK_ROOT>/mcp-servers/cplusplus-analysis/venv/bin/python",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/cplusplus-analysis/mcp_server/cpp_mcp_server.py"
      ],
      "env": {}
    },
    "k8s-gpu": {
      "command": "node",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/k8s-gpu/npm/bin/k8s-gpu-mcp-server"
      ],
      "env": {}
    },
    "nccl-log-parser": {
      "command": "<HPC_STACK_ROOT>/mcp-servers/nccl-log-parser/venv/bin/python",
      "args": [
        "<HPC_STACK_ROOT>/mcp-servers/nccl-log-parser/mcp_server.py"
      ],
      "env": {}
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {}
    }
  }
}
