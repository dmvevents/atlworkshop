# HPC Agent Stack - Environment Variables
# Copy to .env and fill in your API keys:
#   cp .env.example .env
#   nano .env       # fill in keys
#   source .env     # load into shell
#
# API key sources listed below each variable.

# === Model Provider API Keys (Direct Access) ===

# Google Gemini (gemini-3-pro, gemini-2.5-pro, gemini-2.5-flash)
# Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=<YOUR_GOOGLE_API_KEY>

# OpenAI (gpt-5.4, gpt-5.2, o3, o4-mini, codex-5.4)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# === Model Gateway Keys ===

# OpenRouter (300+ models via aggregator)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=<YOUR_OPENROUTER_API_KEY>

# LiteLLM Proxy (self-hosted gateway, generates its own master key on first run)
# Docs: https://docs.litellm.ai/
LITELLM_API_KEY=<YOUR_LITELLM_MASTER_KEY>
LITELLM_PROXY_URL=http://localhost:4000

# === Search & Knowledge Tools ===

# Tavily (AI-optimized web search)
# Get key: https://tavily.com (free tier: 1000 searches/month)
TAVILY_API_KEY=<YOUR_TAVILY_API_KEY>

# Semantic Scholar (academic paper search, free tier works without key)
# Get key: https://www.semanticscholar.org/product/api (optional)
S2_API_KEY=

# RAGFlow (self-hosted RAG, generates its own key on setup)
# Docs: https://ragflow.io/docs/dev/
RAGFLOW_API_KEY=<YOUR_RAGFLOW_API_KEY>
RAGFLOW_URL=http://localhost:9380

# === AWS (uses IAM role or instance profile — no explicit key needed on EC2) ===
AWS_REGION=us-east-2
# AWS_BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# === Service Ports ===
# Zoekt code search:     6070
# OpenGrok symbol xref:  8080
# LiteLLM Proxy:         4000
# RAGFlow:               9380
# All MCP servers:       stdio (no ports)
